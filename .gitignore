# Secretos y configuración local
.env

# Datos privados y generados en tiempo de ejecución
# (usamos data/* en vez de data/ para que !.gitkeep funcione)
data/*
audio/*
historial/*
chroma_db/
models/*
wake_word_data/

# Excepciones: mantener estructura de carpetas vacías
!data/.gitkeep
!audio/.gitkeep
!historial/.gitkeep
!models/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Entorno virtual
venv/
.venv/
env/

# IDEs
.vscode/
.idea/
*.code-workspace
