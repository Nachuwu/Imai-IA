# API key de Groq (STT con whisper-large-v3-turbo — gratis en console.groq.com)
GROQ_API_KEY= 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

# Ciudad por defecto para el clima
CIUDAD=Santiago

# Modelo de lenguaje (debe estar corriendo en Ollama)
MODEL=llama3.2:1b

# Voz de Edge TTS — opciones en español:
#   es-CL-LorenzoNeural  (Chile, masculino)
#   es-CL-CatalinaNeural (Chile, femenino)
#   es-ES-AlvaroNeural   (España, masculino)
#   es-MX-JorgeNeural    (México, masculino)
VOZ=es-CL-LorenzoNeural

# Ruta a la carpeta bin de ffmpeg (para TTS streaming sin reiniciar terminal)
FFMPEG_BIN=C:\Users\ignac\Downloads\ffmpeg-2026-05-06-git-f2e5eff3ff-essentials_build\bin

# --- Hugging Face ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_OFFLINE=1

# --- Audio (ajustar si el micrófono no detecta bien la voz) ---
UMBRAL_RMS=150
SILENCIO_MAX=1.5
DURACION_MAX=15
