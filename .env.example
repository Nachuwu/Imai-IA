# ============================================================
#  IMAI — Configuración de entorno
#  Copia este archivo como .env y rellena los valores reales
# ============================================================

# --- STT (transcripción de voz) ---
# Obtén tu key gratis en console.groq.com → API Keys
# Si no tienes key, Imai usará Whisper local (más lento)
GROQ_API_KEY=

# --- LLM (inteligencia) ---
# Obtén tu key en console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- Clima ---
# Ciudad por defecto para consultas del tiempo
CIUDAD=Santiago

# --- TTS (voz de Imai) ---
# Opciones Edge TTS en español:
#   es-CL-LorenzoNeural  (Chile, masculino)
#   es-CL-CatalinaNeural (Chile, femenino)
#   es-ES-AlvaroNeural   (España, masculino)
#   es-MX-JorgeNeural    (México, masculino)
VOZ=es-CL-LorenzoNeural

# Ruta a la carpeta bin de ffmpeg (necesario para Edge TTS)
# Descarga: https://ffmpeg.org/download.html
FFMPEG_BIN=C:\ruta\a\ffmpeg\bin

# --- Piper TTS (voz local offline, opcional) ---
# Descarga el modelo desde https://github.com/rhasspy/piper/releases
# y ponlo en la carpeta models/
# Deja vacío para usar Edge TTS (requiere internet)
PIPER_MODEL=

# --- Wake word ---
# WAKE_WORD=1  → espera que digas la wake word antes de escuchar
# WAKE_WORD=0  → siempre escucha (modo directo)
WAKE_WORD=1
WAKE_WORD_MODEL=
WAKE_WORD_TARGET=escuchame

# --- Gmail (opcional) ---
# Requiere: data/calendar_credentials.json (credenciales OAuth de Google Cloud)
# El token se genera automáticamente la primera vez (data/gmail_token.json)
# Guía: console.cloud.google.com → habilita Gmail API → OAuth 2.0 Desktop App
GMAIL_ENABLED=0

# --- Google Calendar (opcional) ---
# Requiere: data/calendar_credentials.json (mismo archivo que Gmail)
# Guía: console.cloud.google.com → habilita Calendar API → OAuth 2.0 Desktop App
# 1. Descarga el JSON de credenciales
# 2. Guárdalo en data/calendar_credentials.json
# 3. La primera vez se abrirá el navegador para autorizar
GOOGLE_CALENDAR_ENABLED=0

# --- Telegram (opcional) ---
# Notificaciones de alertas proactivas y recordatorios cuando no estás escuchando a Imai.
# 1. Crea un bot hablando con @BotFather en Telegram → /newbot → copia el token
# 2. Envíale un mensaje a tu bot, luego visita:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    y copia el "chat":{"id": ...} de la respuesta
# Deja ambos vacíos para desactivar esta función.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Audio (ajustar si el micrófono no detecta bien) ---
# UMBRAL_RMS: sensibilidad del micrófono (60-400, menor = más sensible)
UMBRAL_RMS=150
# SILENCIO_MAX: segundos de silencio para cortar la grabación
SILENCIO_MAX=1.5
# DURACION_MAX: duración máxima de grabación en segundos
DURACION_MAX=15

# --- Hugging Face (evitar advertencias de symlinks en Windows) ---
HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_OFFLINE=1
